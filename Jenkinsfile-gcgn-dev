pipeline {
  agent {
    kubernetes {
yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: gradle
    image: gradle:jdk21
    command: ['sleep']
    args: ['infinity']
    volumeMounts:
    - name: maven-repo
      mountPath: /root/.m2
  - name: kaniko
    image: gcr.io/kaniko-project/executor:debug
    command: ['sleep']
    args: ['infinity']
    volumeMounts:
      - name: registry-credentials
        mountPath: /kaniko/.docker
  volumes:
    - name: maven-repo
      persistentVolumeClaim:
        claimName: maven-repo-pvc
    - name: registry-credentials
      secret:
        secretName: ecr-secret
        items:
        - key: .dockerconfigjson
          path: config.json
'''
    }
  }

  parameters {
    // 브랜치 선택 (드롭다운)
    choice(
        name: 'BRANCH_NAME',
        choices: ['develop'],
        description: '배포할 브랜치를 선택하세요. 선택에 따라 Profile(dev/prod), JOOQ_URL(172.19.207.212/172.19.207.210)이 자동 지정됩니다.'
    )

    string name: 'DEPLOY_REMOTE_NAME', defaultValue: 'k8s-manager'
    string name: 'DEPLOY_REMOTE_HOST', defaultValue: '172.19.207.198'
    string name: 'DEPLOY_CREDENTIALS_ID', defaultValue: 'k8s-manager-credential'
    // string name: 'ACTIVE_PROFILE', defaultValue: 'dev'
    // string name: 'JOOQ_URL', defaultValue: 'jdbc:postgresql://172.19.207.210:30432/ailis'
    string name: 'JOOQ_USER', defaultValue: ''
    password name: 'JOOQ_PASSWORD', defaultValue: ''
  }

  environment {
    // 선택된 브랜치에 따라 프로필 자동 매핑
    ACTIVE_PROFILE = "${params.BRANCH_NAME == 'main' ? 'prod' : (params.BRANCH_NAME == 'develop' ? 'dev' : 'none')}"
    JOOQ_URL = "${params.BRANCH_NAME == 'main' ? 'jdbc:postgresql://172.19.207.210:30432/ailis' : (params.BRANCH_NAME == 'develop' ? 'jdbc:postgresql://172.19.207.212:30432/ailis' : 'none')}"
  }

  stages {
    stage('Validate Parameters') {
      steps {
        script {
          // 아무것도 선택하지 않고 빌드했을 경우 중단
          if (env.ACTIVE_PROFILE == 'none') {
            error "❌ [빌드 중단] 올바른 브랜치를 선택해야 합니다!"
          }
          echo "✅ 실행 브랜치: ${params.BRANCH_NAME}"
          echo "✅ 적용 프로필: ${env.ACTIVE_PROFILE}"
          echo "✅ 적용 JOOQ: ${env.JOOQ_URL}"
        }
      }
    }

    stage ('init') {
      steps {
        container('gradle') {
          sh 'git config --global http.sslVerify false'
        }
      }
    }
    stage ('clone') {
      steps {
        echo 'Git clone!!'
        container('gradle') {
          checkout scm
        }
      }
    }
    stage ('define tag') {
      steps {
        container('gradle') {
          script {
            if (env.BUILD_NUMBER.toInteger() % 2 == 1) {
              env.tag = 'blue'
            } else {
              env.tag = 'green'
            }
            echo "tag : ${env.tag}"
          }
        }
      }
    }
    stage('build') {
      steps {
        echo 'Build step!'
        container('gradle') {
          script {
            sh 'chmod 755 gradlew'
            withEnv([
              "JOOQ_URL=${env.JOOQ_URL}",
              "JOOQ_USER=${params.JOOQ_USER}",
              "JOOQ_PASSWORD=${params.JOOQ_PASSWORD}"
            ]) {
              sh './gradlew clean build -x test'
            }
            def grd_version = sh (
              script: "cat build.gradle.kts | grep -o 'version = [^,]*' | awk '{print \$3}'",
              returnStdout: true
            ).trim()
            print grd_version
            env.version = grd_version
          }
        }
      }
    }
    stage('Docker image Build and push') {
      steps {
        echo 'Docker step!'
        container('kaniko') {
          sh "executor --dockerfile=Dockerfile \
          --context=dir://${env.WORKSPACE} \
          --destination=${DOCKER_REGISTRY_URL}/ailis-${env.ACTIVE_PROFILE}/tst-service:${env.ACTIVE_PROFILE}-${env.version}-${BUILD_NUMBER}"
        }
      }
    }
    stage('deploy') {
      steps {
        script {
            def remote = [:]
            remote.name = "${DEPLOY_REMOTE_NAME}"
            remote.host = "${DEPLOY_REMOTE_HOST}"
            remote.port = 22
            remote.allowAnyHosts = true

            def sshId = "${DEPLOY_CREDENTIALS_ID}"
            withCredentials([sshUserPrivateKey(credentialsId: sshId, keyFileVariable: 'identity', passphraseVariable: '', usernameVariable: 'userName')]) {
                remote.user = userName
                remote.identityFile = identity
                stage("SSH Docker run") {
                    sshCommand remote: remote, command: "sed -e \"s/REPLACE_BUILD_VERSION_NUMBER/${env.ACTIVE_PROFILE}-${env.version}-${BUILD_NUMBER}/g\" -e \"s/REPLACE_TAG/${env.tag}/g\" -e \"s/REPLACE_PROFILE/${env.ACTIVE_PROFILE}/g\" ~/workspace/ailis-deploy/ailis/auto-deploy-temp/tst-deployment.template > ~/workspace/ailis-deploy/ailis/${env.ACTIVE_PROFILE}/tst-deployment.yaml"
                    sshCommand remote: remote, command: "kubectl apply -f ~/workspace/ailis-deploy/ailis/${env.ACTIVE_PROFILE}/tst-deployment.yaml"
                }
            }
        }
      }
    }
    stage('switching LB') {
      steps {
        script {
          def remote = [:]
          remote.name = "${DEPLOY_REMOTE_NAME}"
          remote.host = "${DEPLOY_REMOTE_HOST}"
          remote.port = 22
          remote.allowAnyHosts = true

          def sshId = "${DEPLOY_CREDENTIALS_ID}"
          withCredentials([sshUserPrivateKey(credentialsId: sshId, keyFileVariable: 'identity', passphraseVariable: '', usernameVariable: 'userName')]) {
            remote.user = userName
            remote.identityFile = identity
            stage("SSH Docker run") {
                sshCommand remote: remote, command: "sh ~/workspace/ailis-deploy/ailis/lb/switchingLb.sh tst-dep ${env.tag} tst-service ${env.ACTIVE_PROFILE}"
            }
          }
        }
      }
    }
  }
}
