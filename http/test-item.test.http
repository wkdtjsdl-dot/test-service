### 관리자 Login 요청 (테스트용)
POST {{api-service}}/api/auth/adminLogin
Content-Type: application/json
Accept: application/json

{
  "adminId": "TEST003",
  "passwd": "test1234"
}

> {%
    client.global.set("accessToken", response.headers.valuesOf("Set-Cookie")
        .find(function(cookie) { return (cookie.split(";")[0].split("=")[0] === "accessToken"); } ).split(";")[0].split("=")[1]
    );
    client.global.set("refreshToken", response.headers.valuesOf("Set-Cookie")
        .find(cookie => cookie.split(";")[0].split("=")[0] === "refreshToken").split(";")[0].split("=")[1]
    );
    client.log("global 쿠키: accessToken="+client.global.get("accessToken") + "\n          refreshToken="+ client.global.get("refreshToken"));
%}

###########################
# 검사항목 (Test Item)
###########################

### 검사 검사종목 목록
GET {{api-service}}/api/tst/bts/item
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 검사 검사종목 목록 (대분류별)
GET {{api-service}}/api/tst/bts/item/by-large-cate/01
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 검사 검사종목 기본정보 조회
GET {{api-service}}/api/tst/bts/item/base/TST001
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 검사 검사종목 기본정보 등록
POST {{api-service}}/api/tst/bts/item/base
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

{
  "tstCd": "TEST_ITEM01",
  "tstLargeCateCd": "01",
  "tstMediumCateCd": "01",
  "useTypeFlag": true,
  "tstNm": "테스트 검사항목",
  "tstAbbrNm": "테스트항목",
  "tstEngNm": "Test Item",
  "tstEngAbbrNm": "TestItem",
  "sortOrder": 1,
  "sameJudge": "N",
  "tstGroupCd": "GRP01",
  "tstSubsidyCd": "SUB01",
  "tstMaterialCd": "MAT01",
  "printOrder": 1,
  "deleteYn": false,
  "externalYn": false,
  "sendYn": false,
  "autoInputYn": false,
  "resultInputTimeLimit": 24
}

### 검사 검사종목 기본정보 수정
PUT {{api-service}}/api/tst/bts/item/base/TEST_ITEM01
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

{
  "tstLargeCateCd": "02",
  "tstMediumCateCd": "02",
  "useTypeFlag": false,
  "tstNm": "수정된 검사항목",
  "tstAbbrNm": "수정항목",
  "tstEngNm": "Updated Test Item",
  "tstEngAbbrNm": "UpdItem",
  "sortOrder": 2,
  "sameJudge": "Y",
  "tstGroupCd": "GRP02",
  "tstSubsidyCd": "SUB02",
  "tstMaterialCd": "MAT02",
  "printOrder": 2,
  "deleteYn": false,
  "externalYn": true,
  "sendYn": true,
  "autoInputYn": true,
  "resultInputTimeLimit": 48
}

### 검사 검사종목 기본정보 삭제
DELETE {{api-service}}/api/tst/bts/item/base/TEST_ITEM01
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 검사 코드 자동완성 (검색어로 검색)
GET {{api-service}}/api/tst/bts/item/auto-complete?keyword=테스트
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 검사 코드 자동완성 (검사 코드로 검색)
GET {{api-service}}/api/tst/bts/item/auto-complete?keyword=N119
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 검사 코드 innerApi 조회
GET {{tst-service}}/api/inner/bts/item?cds=N119,N110,N112
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}


