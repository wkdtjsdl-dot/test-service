### 관리자 Login 요청
POST {{api-service}}/api/auth/adminLogin
Content-Type: application/json
Accept: application/json

{
  "adminId": "TEST001",
  "passwd": "test1234"
}

> {%
    client.global.set("accessToken", response.headers.valuesOf("Set-Cookie")
        .find(function(cookie) { return (cookie.split(";")[0].split("=")[0] === "accessToken"); } ).split(";")[0].split("=")[1]
    );
    client.global.set("refreshToken", response.headers.valuesOf("Set-Cookie")
        .find(cookie => cookie.split(";")[0].split("=")[0] === "refreshToken").split(";")[0].split("=")[1]
    );
    client.log("global 쿠키: accessToken="+client.global.get("accessToken") + "\n          refreshToken="+ client.global.get("refreshToken"));
%}

### 영업담당자 목록 조회
GET {{api-service}}/api/sals/custs/sals-pics?custMstId=36973D74-A010-4975-A5EE-9B8697F28C51&page=0&size=10
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 영업담당자 상세 조회
GET {{api-service}}/api/sals/custs/sals-pics/6
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 영업담당자 등록
POST {{api-service}}/api/sals/custs/sals-pics
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

{
  "custMstId": "36973D74-A010-4975-A5EE-9B8697F28C51",
  "applyStartDt": "2023-01-01",
  "salsTeamCd": "SLTM_TS-C",
  "empUserId": "TEST001",
  "custCd": "G010000",
  "applyEndDt": null
}

### 영업담당자 수정
PUT {{api-service}}/api/sals/custs/sals-pics/8
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

{
  "custMstId": "CUST001",
  "applyStartDt": "2023-01-01",
  "salsTeamCd": "TEAM_C",
  "empUserID": "TEST001",
  "custCd": "CUST001",
  "applyEndDt": null
}

