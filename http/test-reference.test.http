Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

{
  "refGroupCd": "GRP001",
  "refCd": "REF001",
  "sortOrder": 1
}

### 검사 기준정보 검사 참조그룹 참조항목 수정
PUT {{api-service}}/api/tst/bbs/tst-ref-group-item/TEST_ITEM01
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

{
  "refGroupCd": "GRP002",
  "refCd": "REF002",
  "sortOrder": 2
}

### 검사 기준정보 검사 참조그룹 참조항목 삭제
DELETE {{api-service}}/api/tst/bbs/tst-ref-group-item/TEST_ITEM01
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}
