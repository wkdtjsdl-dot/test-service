### 관리자 Login 요청
POST {{api-service}}/api/auth/adminLogin
Content-Type: application/json
Accept: application/json

{
  "adminId": "TEST001",
  "passwd": "test1234"
}

> {%
    client.global.set("accessToken", response.headers.valuesOf("Set-Cookie")
        .find(function(cookie) { return (cookie.split(";")[0].split("=")[0] === "accessToken"); } ).split(";")[0].split("=")[1]
    );
    client.global.set("refreshToken", response.headers.valuesOf("Set-Cookie")
        .find(cookie => cookie.split(";")[0].split("=")[0] === "refreshToken").split(";")[0].split("=")[1]
    );
    client.log("global 쿠키: accessToken="+client.global.get("accessToken") + "\n          refreshToken="+ client.global.get("refreshToken"));
%}


### 고객 수가 등록
POST {{api-service}}/api/sals/custs/charges
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

{
  "custCd": "CUST001",
  "applyStartDt": "2024-01-01",
  "applyEndDt": "2024-12-31",
  "tstCd": "T1234",
  "crcyCd": "KRW",
  "stndPrice": 100000,
  "specialCharge": 80000,
  "supval": 80000,
  "addtax": 8000,
  "remark": "신규 고객 수가 등록 테스트"
}

### 고객 수가 단건 조회
GET {{api-service}}/api/sals/custs/charges/d13bc58e-58d0-402c-96a6-a9d265fcd5de
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 고객 수가 목록 조회 (페이지)
GET {{api-service}}/api/sals/custs/charges?page=0&size=10
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 고객 수가 목록 조회 (담당사원 이름 또는 ID로 검색)
GET {{api-service}}/api/sals/custs/charges?empUserIdNm=홍길동&page=0&size=10
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 고객 수가 목록 조회 (전체)
GET {{api-service}}/api/sals/custs/charges/list?empUserIdNm=김
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

###

### 고객 수가 목록 조회 (적용 시작일로 검색)
GET {{api-service}}/api/sals/custs/charges/list?dateSearchType=start&startDt=2024-01-01&endDt=2024-06-30&page=0&size=10
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}
