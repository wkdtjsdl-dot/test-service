### 관리자 Login 요청
POST {{api-service}}/api/auth/adminLogin
Content-Type: application/json
Accept: application/json

{
  "adminId": "TEST003",
  "passwd": "test1234"
}

> {%
    client.global.set("accessToken", response.headers.valuesOf("Set-Cookie")
        .find(function(cookie) { return (cookie.split(";")[0].split("=")[0] === "accessToken"); } ).split(";")[0].split("=")[1]
    );
    client.global.set("refreshToken", response.headers.valuesOf("Set-Cookie")
        .find(cookie => cookie.split(";")[0].split("=")[0] === "refreshToken").split(";")[0].split("=")[1]
    );
    client.log("global 쿠키: accessToken="+client.global.get("accessToken") + "\n          refreshToken="+ client.global.get("refreshToken"));
%}

### 견적서 목록 조회 (전체)
GET {{api-service}}/api/v1/estimates?startDt=2026-01-01&endDt=2026-01-31&page=0&size=15
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 견적서 목록 조회 (견적서만)
GET {{api-service}}/api/v1/estimates?startDt=2026-01-01&endDt=2026-01-31&docType=EST&page=0&size=15
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 견적서 목록 조회 (거래명세서만)
GET {{api-service}}/api/v1/estimates?startDt=2026-01-01&endDt=2026-01-31&docType=TRN&page=0&size=15
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 견적서 목록 조회 (수신처 검색)
GET {{api-service}}/api/v1/estimates?startDt=2026-01-01&endDt=2026-01-31&receiver=서울대학교병원&page=0&size=15
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 견적서 생성 (견적서)
POST {{api-service}}/api/v1/estimates
Content-Type: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

{
  "docType": "EST",
  "regDt": "2026-01-05",
  "title": "유전자 검사 견적서",
  "receiver": "서울대학교병원",
  "reference": "진단의학과",
  "writerEmpNo": "EMP001",
  "deptCd": "DEPT001",
  "remark": "2026년 1분기",
  "note": "특이사항 없음",
  "items": [
    {
      "itemNm": "BRCA1/2 유전자 검사",
      "qty": 100,
      "unitPrice": 90000
    },
    {
      "itemNm": "Lynch 증후군 유전자 검사",
      "qty": 50,
      "unitPrice": 120000
    }
  ]
}

> {%
    client.global.set("estimateId", response.body.estimateId);
    client.log("Created estimateId: " + client.global.get("estimateId"));
%}

### 견적서 생성 (거래명세서)
POST {{api-service}}/api/v1/estimates
Content-Type: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

{
  "docType": "TRN",
  "regDt": "2026-01-05",
  "title": "12월 거래명세서",
  "receiver": "서울대학교병원",
  "reference": "진단의학과",
  "writerEmpNo": "EMP001",
  "deptCd": "DEPT001",
  "remark": "2025년 12월",
  "note": "",
  "items": [
    {
      "itemNm": "각종 유전자 검사",
      "qty": 200,
      "unitPrice": 85000
    }
  ]
}

> {%
    client.global.set("estimateId2", response.body.estimateId);
    client.log("Created estimateId2: " + client.global.get("estimateId2"));
%}

### 견적서 상세 조회
GET {{api-service}}/api/v1/estimates/{{estimateId}}
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 견적서 수정
PUT {{api-service}}/api/v1/estimates/{{estimateId}}
Content-Type: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

{
  "docType": "EST",
  "regDt": "2026-01-05",
  "title": "유전자 검사 견적서 (수정)",
  "receiver": "서울대학교병원",
  "reference": "진단의학과",
  "writerEmpNo": "EMP001",
  "deptCd": "DEPT001",
  "remark": "2026년 1분기 (수정)",
  "note": "할인율 10% 적용",
  "items": [
    {
      "itemNm": "BRCA1/2 유전자 검사",
      "qty": 120,
      "unitPrice": 85000
    },
    {
      "itemNm": "Lynch 증후군 유전자 검사",
      "qty": 60,
      "unitPrice": 110000
    },
    {
      "itemNm": "PALB2 유전자 검사",
      "qty": 30,
      "unitPrice": 95000
    }
  ]
}

> {%
    client.log("Updated estimateId: " + client.global.get("estimateId"));
%}

### 견적서 삭제
DELETE {{api-service}}/api/v1/estimates/{{estimateId2}}
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}
