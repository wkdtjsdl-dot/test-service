### 관리자 Login 요청
POST {{api-service}}/api/auth/adminLogin
Content-Type: application/json
Accept: application/json

{
  "adminId": "TEST001",
  "passwd": "test1234"
}

> {%
    client.global.set("accessToken", response.headers.valuesOf("Set-Cookie")
        .find(function(cookie) { return (cookie.split(";")[0].split("=")[0] === "accessToken"); } ).split(";")[0].split("=")[1]
    );
    client.global.set("refreshToken", response.headers.valuesOf("Set-Cookie")
        .find(cookie => cookie.split(";")[0].split("=")[0] === "refreshToken").split(";")[0].split("=")[1]
    );
    client.log("global 쿠키: accessToken="+client.global.get("accessToken") + "\n          refreshToken="+ client.global.get("refreshToken"));
%}

### 고객 계약 목록 조회
GET {{api-service}}/api/sals/custs/cntrs?custMstId=36973D74-A010-4975-A5EE-9B8697F28C51
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 고객 계약 상세 조회
GET {{api-service}}/api/sals/custs/cntrs/1
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 고객 계약 등록
POST {{api-service}}/api/sals/custs/cntrs?custMstId=36973D74-A010-4975-A5EE-9B8697F28C51
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

{
  "custCd": "CONTRACT_CUST_CD",
  "cntrNo": "CNTR-001",
  "cntrDt": "2023-01-01",
  "cntrStartDt": "2023-01-01",
  "cntrEndDt": "2023-12-31",
  "cntrType": "TYPE_A",
  "recntrMonth": "12",
  "cntrNm": "Test Contract 1",
  "cntrCont": "Contract content details",
  "cntrPicId": "TEST002",
  "atchGrupId": "ATCH001",
  "useYn": true
}

### 고객 계약 수정
PUT {{api-service}}/api/sals/custs/cntrs/7?custMstId=36973D74-A010-4975-A5EE-9B8697F28C51
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

{
  "custCd": "CONTRACT_CUST_CD_UPDATED7",
  "cntrNo": "CNTR-001-UPDATED",
  "cntrDt": "2023-01-01",
  "cntrStartDt": "2023-01-01",
  "cntrEndDt": "2024-12-31",
  "cntrType": "TYPE_B",
  "recntrMonth": "12",
  "cntrNm": "Updated Test Contract 1",
  "cntrCont": "Updated contract content details",
  "cntrPicId": "TEST003",
  "atchGrupId": "ATCH001",
  "useYn": true
}
