### 관리자 Login 요청
POST {{api-service}}/api/auth/adminLogin
Content-Type: application/json
Accept: application/json

{
  "adminId": "TEST003",
  "passwd": "test1234"
}

> {%
    client.global.set("accessToken", response.headers.valuesOf("Set-Cookie")
        .find(function(cookie) { return (cookie.split(";")[0].split("=")[0] === "accessToken"); } ).split(";")[0].split("=")[1]
    );
    client.global.set("refreshToken", response.headers.valuesOf("Set-Cookie")
        .find(cookie => cookie.split(";")[0].split("=")[0] === "refreshToken").split(";")[0].split("=")[1]
    );
    client.log("global 쿠키: accessToken="+client.global.get("accessToken") + "\n          refreshToken="+ client.global.get("refreshToken"));
%}

### Exim 환율 OpenAPI 테스트
GET https://oapi.koreaexim.go.kr/site/program/financial/exchangeJSON?authkey={{EXIM_KEY}}&data=AP01&searchdate=20251124
Accept: application/json

### 환율 배치 등록 (내부 API)
POST {{sales-service}}/api/inner/custs/exrt/batch
Content-Type: application/json

[
  {
    "stndDt": "2025-11-25",
    "crcyCd": "USD",
    "stndExrt": 1350.50
  },
  {
    "stndDt": "2025-11-24",
    "crcyCd": "JPY",
    "stndExrt": 9.25
  },
  {
    "stndDt": "2025-11-24",
    "crcyCd": "EUR",
    "stndExrt": 1450.80
  }
]

### 환율 목록 조회 (날짜 범위 + 통화코드)
GET {{api-service}}/api/sals/custs/exrt?stndDtFrom=2025-02-01&stndDtTo=2025-02-28&crcyCd=USD&page=0&size=15
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 환율 목록 조회 (전체)
GET {{api-service}}/api/sals/custs/exrt?page=0&size=15
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 환율 상세 조회
GET {{api-service}}/api/sals/custs/exrt/1
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 환율 수정 (stndExrt만 수정 가능)
PUT {{api-service}}/api/sals/custs/exrt/1
Content-Type: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

{
  "stndExrt": 1355.00
}