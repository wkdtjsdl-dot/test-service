###########################
# 테스트 데이터 시나리오
###########################

### 시나리오 1: 보고서 등록 → 조회 → 배포
# 1단계: 보고서 등록
POST {{api-service}}/api/tst/bts/tst-report
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

{
  "tstReqDt": "2024-12-18",
  "tstReqNo": 3001,
  "tstCd": "TST003",
  "rstShort": "시나리오 테스트",
  "rstTxt": "시나리오 테스트용 보고서입니다.",
  "rstFileNm": "scenario_test.pdf",
  "rstFileExt": "pdf",
  "rstFilePath": "/reports/2024/12/scenario_test.pdf",
  "memo": "시나리오 테스트"
}

> {%
    client.global.set("scenarioReportId", response.body.tstReportId);
    client.log("시나리오 reportId: " + client.global.get("scenarioReportId"));
%}

### 시나리오 2단계: 생성된 보고서 조회
GET {{api-service}}/api/tst/bts/tst-report/{{scenarioReportId}}
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 시나리오 3단계: 보고서 배포
POST {{api-service}}/api/tst/bts/tst-report/{{scenarioReportId}}/deliver
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

{
  "deliveryMethod": "EMAIL"
}

### 시나리오 4단계: 배포 후 다시 조회 (deliveryYn 확인)
GET {{api-service}}/api/tst/bts/tst-report/{{scenarioReportId}}
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}