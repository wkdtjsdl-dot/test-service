### 관리자 Login 요청
POST {{api-service}}/api/auth/adminLogin
Content-Type: application/json
Accept: application/json

{
  "adminId": "TEST001",
  "passwd": "test1234"
}

> {% 
    client.global.set("accessToken", response.headers.valuesOf("Set-Cookie")
        .find(function(cookie) { return (cookie.split(";")[0].split("=")[0] === "accessToken"); } ).split(";")[0].split("=")[1]
    );
    client.global.set("refreshToken", response.headers.valuesOf("Set-Cookie")
        .find(cookie => cookie.split(";")[0].split("=")[0] === "refreshToken").split(";")[0].split("=")[1]
    );
    client.log("global 쿠키: accessToken="+client.global.get("accessToken") + "\n          refreshToken="+ client.global.get("refreshToken"));
%}

### 고객 연락처 목록 조회
GET {{api-service}}/api/sals/custs/CUST001/contacts?page=0&size=10
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 고객 연락처 상세 조회
GET {{api-service}}/api/sals/custs/CUST001/contacts/1
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

### 고객 연락처 등록
POST {{api-service}}/api/sals/custs/CUST001/contacts
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

{
  "custMstId": "CUST001",
  "custCd": "CUST001",
  "acctChargeNm": "홍길동",
  "ofpoJbpo": "과장",
  "telno": "02-1234-5678",
  "phno": "010-1234-5678",
  "email": "hong.gildong@example.com",
  "remark": "테스트 비고",
  "useYn": true
}

### 고객 연락처 수정
PUT {{api-service}}/api/sals/custs/CUST001/contacts/1
Content-Type: application/json
Accept: application/json
Cookie: accessToken={{accessToken}}; refreshToken={{refreshToken}}

{
  "custMstId": "CUST001",
  "custCd": "CUST001",
  "acctChargeNm": "김철수",
  "ofpoJbpo": "부장",
  "telno": "02-9876-5432",
  "phno": "010-9876-5432",
  "email": "kim.chulsoo@example.com",
  "remark": "수정된 비고",
  "useYn": true
}